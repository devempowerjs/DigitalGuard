{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],

  "outputDirectory": "dist",
  "cleanUrls": true,

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:;"
        }
      ]
    }
  ],

  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

